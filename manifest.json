{
  "manifest_version": 2,
  "name": "srtfy",
  "browser_specific_settings": {
    "gecko": {
      "id": "srtfy@local"
    }
  },
  "version": "1.0",
  "description": "Load local SRT subtitles onto any video in the browser.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
